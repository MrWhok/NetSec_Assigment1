# Flask settings
FLASK_SECRET_KEY=change-this-secret
SESSION_COOKIE_SECURE=false

# Keycloak OAuth settings
KEYCLOAK_CLIENT_ID=web-app
KEYCLOAK_CLIENT_SECRET=replace-with-client-secret
KEYCLOAK_SERVER_METADATA_URL=https://123.456.78.90:8443/auth/realms/master/.well-known/openid-configuration
KEYCLOAK_SCOPE=openid profile email
KEYCLOAK_VERIFY_TLS=false
KEYCLOAK_CALLBACK_URL=http://123.456.78.90:5000/callback

# App runtime
APP_HOST=0.0.0.0
APP_PORT=5000

# Flask settings
FLASK_SECRET_KEY=change-this-secret

# Ory Hydra OAuth settings
OIDC_CLIENT_ID=replace-with-hydra-client-id
OIDC_CLIENT_SECRET=replace-with-hydra-client-secret
OIDC_SCOPE=openid profile email

# Browser-facing endpoints
OIDC_ISSUER=http://127.0.0.1:4444
OIDC_AUTHORIZATION_ENDPOINT=http://127.0.0.1:4444/oauth2/auth
OIDC_CALLBACK_URL=http://localhost:5000/callback

# Container back-channel endpoints
OIDC_TOKEN_ENDPOINT=http://hydra:4444/oauth2/token
OIDC_USERINFO_ENDPOINT=http://hydra:4444/userinfo
OIDC_JWKS_URI=http://hydra:4444/.well-known/jwks.json

# App runtime
APP_HOST=0.0.0.0
APP_PORT=5000
